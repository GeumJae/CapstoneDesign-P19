<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAF8FF"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="28dp">

    <!-- 로고 아이콘 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🎭"
        android:textSize="42sp"
        android:layout_marginBottom="12dp" />

    <!-- 앱 타이틀 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MBTI 커뮤니티"
        android:textColor="#000000"
        android:textSize="30sp"
        android:textStyle="normal"
        android:layout_marginBottom="12dp" />

    <!-- 설명 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="나와 맞는 사람들과 소통하세요"
        android:textColor="#344767"
        android:textSize="16sp"
        android:layout_marginBottom="64dp" />

    <!-- 카카오 로그인 버튼 -->
    <Button
        android:id="@+id/btn_login"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/rounded_button"
        android:backgroundTint="#FEE500"
        android:text="💬   카카오로 시작하기"
        android:textColor="#000000"
        android:textSize="17sp"
        android:textStyle="bold" />

    <!-- 안내 문구 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:text="카카오 로그인으로 회원가입 및 로그인이 가능합니다"
        android:textColor="#6C6F85"
        android:textSize="14sp" />

</LinearLayout>